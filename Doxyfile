PROJECT_NAME			= "uRTOS"
PROJECT_BRIEF			= "Lightweight RTOS for AVR"
OUTPUT_DIRECTORY		= docs
OPTIMIZE_OUTPUT_FOR_C	= YES
EXTRACT_ALL				= YES
EXTRACT_STATIC			= YES
INPUT					= include src
RECURSIVE				= YES
GENERATE_HTML			= YES
GENERATE_LATEX			= NO

# Fix attributes
ENABLE_PREPROCESSING	= YES
MACRO_EXPANSION			= YES
EXPAND_ONLY_PREDEF		= YES

PREDEFINED				+= __attribute__(x)=
PREDEFINED				+= __extension__=
PREDEFINED				+= __restrict=